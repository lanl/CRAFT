<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Cleaning Metadata-->
    <cleaning_metadata>
        <drive>Xiulin_runs/</drive><!--your files are located at $drive$case<-->
        <case>TwoSites-PreIndust-AllParams-ens-DBH10_bypft-002</case> 
        <n_runs>999</n_runs><!--Assumes these are 0-999<-->
        <varlist>Date,fates_basal_area,fates_nplant</varlist> <!--Always start with Date <-->
        <timestep>Month,PFTannMax,DIAannMax</timestep><!--Current options are Month, DayMin, DayMax, PFTannMean<-->
        <parameter_loc>fates-parameters-sampled.csv</parameter_loc><!--File with parameter combination <-->
    </cleaning_metadata>

    <!-- Neural Network Configuration-->
    <nn_config>
        <layer_sizes>44,1280,640,256,128,64,32,1</layer_sizes> <!--From top to bottom <-->
        <activation>relu</activation><!--Add dropout layers <-->
        <optimizer>adam</optimizer>
        <loss>mse</loss>
        <epochs>20</epochs>
        <batch_size>100</batch_size>
    </nn_config>

    <!-- Emulator Metadata-->
    <emulator_metadata>
        <save_name>CRAFT_Xulin</save_name>
        <thres>0.001</thres>
        <emulator_drive>data/Vars/</emulator_drive>
        <fates_samples>fates-parameters-sampled.csv</fates_samples><!--Should be in CRAFT main <-->
        <model_type>rf</model_type><!--rf/nn--> 
        <nn_config>nn_config.csv</nn_config>
    </emulator_metadata>

    <!-- Emulator Settings-->
    <emulator_settings>
        <variable>
            <var_name>[fates_basal_area,fates_nplant]</var_name>
            <fates_runs>[fates_basal_areaPFTannMean.csv,fates_nplantPFTannMean.csv]</fates_runs>
            <xs>[2,2]</xs> <!--where are the variables pythonic x_start<-->
            <xe>[26,26]</xe><!-- x_end<-->
            <y_i>[1,1]</y_i><!--where is y<-->
            <scaler>[1,1]</scaler><!-- scale_y<-->
            <downsample>[1,1]</downsample><!-- downsample very large projects on small computer. <-->
        </variable>
    </emulator_settings>

    <!-- Bayes Settings -->
    <bayes_settings>
        <initialpos>45</initialpos>
        <model_type>Xiulin_rf</model_type>
        <steps>2000</steps>
        <adapt_interval>1000</adapt_interval>
        <burnin>200</burnin>
        <model_list>['CRAFT_Xulinfates_basal_area','CRAFT_Xulinfates_nplant']</model_list>
        <scaler_list>['CRAFT_Xulinfates_basal_area_Scalar','CRAFT_Xulinfates_nplant_Scalar']</scaler_list>
        <obs_list>["PFT1_BA_case1","PFT2_BA_case1","PFT3_BA_case1","PFT4_BA_case1",
                      "PFT1_BA_case2","PFT2_BA_case2","PFT3_BA_case2","PFT4_BA_case2",
                      "Stem_DIA1_case1", "Stem_DIA5_case1","Stem_DIA6_case1",
                      "Stem_DIA5_case2","Stem_DIA6_case2"]</obs_list>
        <list1>["PFT1_BA_case1","PFT2_BA_case1","PFT3_BA_case1","PFT4_BA_case1",
                      "PFT1_BA_case2","PFT2_BA_case2","PFT3_BA_case2","PFT4_BA_case2",
                      "Stem_DIA1_case1", "Stem_DIA5_case1","Stem_DIA6_case1",
                      "Stem_DIA5_case2","Stem_DIA6_case2"]</list1>
        <samples_file>fates-parameters-sampled.csv</samples_file>
        <obsfile>Xiulin_Observation.csv</obsfile>
        <output_file>data/MCMC_runs/TestXiulin.csv</output_file>        
        <!-- MCMC Sampler Selection: 'adaptive' or 'dream' -->
        <sampler_method>dream</sampler_method>
        <!-- DREAM-specific settings (only used when sampler_method='dream') -->
        <dream_n_chains>3</dream_n_chains>
        <dream_delta>1 </dream_delta>
        <dream_c>0.01</dream_c>
        <dream_c_star>1e-12</dream_c_star>
        <dream_n_crossover>3</dream_n_crossover>
        <dream_p_gamma_unity>0.1</dream_p_gamma_unity>
        <dream_thin>1</dream_thin>
    </bayes_settings>
</configuration>
