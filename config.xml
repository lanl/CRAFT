<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Cleaning Metadata-->
    <cleaning_metadata>
        <drive>C:/Users/345578/Documents/GitHub/CRAFT/output_SLZ_2pft.IELMFATES/</drive>
        <case>SLZ_2pft.IELMFATES</case>
        <n_runs>1000</n_runs>
        <varlist>Date,FATES_GPP,H2OSOIvalue1,FATES_LEAF_H2OPOT_SZPF_12,FATES_LEAF_H2OPOT_SZPF_24,FATES_LEAF_H2OPOT_SZPF_12,FATES_LEAF_H2OPOT_SZPF_24</varlist> <!--Always start with Date <-->
        <timestep>Month,Month,Month,DayMin,DayMin,DayMax,DayMax</timestep>
        <parameter_loc>FATES_Param_samples_slz_forML.csv</parameter_loc>
    </cleaning_metadata>

    <!-- Neural Network Configuration-->
    <nn_config>
        <layer_sizes>44,1280,640,256,128,64,32,1</layer_sizes>
        <activation>relu</activation>
        <optimizer>adam</optimizer>
        <loss>mse</loss>
        <epochs>50</epochs>
        <batch_size>100</batch_size>
    </nn_config>

    <!-- Emulator Metadata-->
    <emulator_metadata>
        <settings_file>Emulator_Fitting_Settings1.csv</settings_file>
        <save_name>CRAFT_practice_Full</save_name>
        <thres>0.03</thres>
        <emulator_drive>data/Vars/</emulator_drive>
        <fates_samples>FATES_Param_samples_slz_forML.csv</fates_samples>
        <model_type>rf</model_type>
        <nn_config>nn_config.csv</nn_config>
    </emulator_metadata>

    <!-- Emulator Settings-->
    <emulator_settings>
        <variable>
            <var_name>[H2OSOIvalue1,PFT1_LWPMax,PFT1_LWPMin,PFT2_LWPMax,PFT2_LWPMin]</var_name>
            <fates_runs>[H2OSOIvalue1MonthlyforML.csv,FATES_LEAF_H2OPOT_SZPF_12DailymaxforML.csv,FATES_LEAF_H2OPOT_SZPF_12DailyminforML.csv,FATES_LEAF_H2OPOT_SZPF_24DailymaxforML.csv,FATES_LEAF_H2OPOT_SZPF_24DailyminforML.csv]</fates_runs>
            <xs>[5,5,5,5,5]</xs>
            <xe>[40,40,40,40,40]</xe>
            <y_i>[3,3,3,3,3]</y_i>
            <scaler>[1,1e-6,1e-6,1e-6,1e-6]</scaler>
            <downsample>[1,.1,.1,.1,.1]</downsample>
        </variable>
    </emulator_settings>

    <!-- Bayes Settings -->
    <bayes_settings>
        <initialpos>45</initialpos>
        <steps>2000</steps>
        <adapt_interval>1000</adapt_interval>
        <burnin>1000</burnin>
        <model_list>['CRAFT_practice_FullH2OSOIvalue1','CRAFT_practice_FullPFT1_LWPMin','CRAFT_practice_FullPFT2_LWPMin']</model_list>
        <scaler_list>['CRAFT_practice_FullH2OSOIvalue1_Scalar','CRAFT_practice_FullPFT1_LWPMin_Scalar','CRAFT_practice_FullPFT2_LWPMin_Scalar']</scaler_list>
        <obs_list>["H2OSOI1",'LWP_min','LWP_min']</obs_list>
        <list1>["H2OSOI1",'LWP_min','LWP_min']</list1>
        <samples_file>FATES_Param_samples_slz_forML.csv</samples_file>
        <obsfile>Example_Obs_data/SLZ_Observations.csv</obsfile>
        <output_file>data/MCMC_runs/TestSLZ.csv</output_file>        
        <!-- MCMC Sampler Selection: 'adaptive' or 'dream' -->
        <sampler_method>dream</sampler_method>
        <!-- DREAM-specific settings (only used when sampler_method='dream') -->
        <dream_n_chains>5</dream_n_chains>
        <dream_delta>2</dream_delta>
        <dream_c>0.1</dream_c>
        <dream_c_star>1e-12</dream_c_star>
        <dream_n_crossover>3</dream_n_crossover>
        <dream_p_gamma_unity>0.2</dream_p_gamma_unity>
        <dream_thin>1</dream_thin>
    </bayes_settings>
</configuration>
