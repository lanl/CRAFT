<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Cleaning Metadata-->
    <cleaning_metadata>
        <drive>C:/Users/345578/Documents/GitHub/CRAFT/output_BCI_2pft.IELMFATES/</drive>
        <case>BCI_2pft.IELMFATES</case>
        <n_runs>1000</n_runs>
        <varlist>Date,FATES_GPP</varlist> <!--Always start with Date <-->
        <timestep>Month,Month</timestep>
        <parameter_loc>FATES_Param_samples_bci.csv</parameter_loc>
    </cleaning_metadata>

    <!-- Neural Network Configuration-->
    <nn_config>
        <layer_sizes>44,1280,640,256,128,64,32,1</layer_sizes>
        <activation>relu</activation>
        <optimizer>adam</optimizer>
        <loss>mse</loss>
        <epochs>50</epochs>
        <batch_size>100</batch_size>
    </nn_config>

    <!-- Emulator Metadata-->
    <emulator_metadata>
        <settings_file>Emulator_Fitting_Settings1.csv</settings_file>
        <save_name>CRAFT_practice_Full</save_name>
        <thres>0.03</thres>
        <emulator_drive>data/Vars/</emulator_drive>
        <fates_samples>FATES_Param_samples_slz_forML.csv</fates_samples>
        <model_type>rf</model_type>
        <nn_config>nn_config.csv</nn_config>
    </emulator_metadata>

    <!-- Emulator Settings-->
    <emulator_settings>
        <variable>
            <var_name>[FATES_GPP]</var_name>
            <fates_runs>[FATES_GPPMonthlyforML.csv]</fates_runs>
            <xs>[5]</xs>
            <xe>[40]</xe>
            <y_i>[3]</y_i>
            <scaler>[1e6]</scaler>
            <downsample>[1]</downsample>
        </variable>
    </emulator_settings>

    <!-- Bayes Settings -->
    <bayes_settings>
        <initialpos>45</initialpos>
        <steps>2000</steps>
        <adapt_interval>1000</adapt_interval>
        <burnin>1000</burnin>
        <model_list>['CRAFT_practice_FullFATES_GPP']</model_list>
        <scaler_list>['CRAFT_practice_FullFATES_GPP_Scalar']</scaler_list>
        <obs_list>["MonthlyGPP"]</obs_list>
        <list1>["MonthlyGPP"]</list1>
        <samples_file>FATES_Param_samples_slz_forML.csv</samples_file>
        <obsfile>Example_Obs_data/Syntheticg_Set2_63025.csv</obsfile>
        <output_file>data/MCMC_runs/TestSLZ.csv</output_file>        
        <!-- MCMC Sampler Selection: 'adaptive' or 'dream' -->
        <sampler_method>dream</sampler_method>
        <!-- DREAM-specific settings (only used when sampler_method='dream') -->
        <dream_n_chains>5</dream_n_chains>
        <dream_delta>2</dream_delta>
        <dream_c>0.1</dream_c>
        <dream_c_star>1e-12</dream_c_star>
        <dream_n_crossover>3</dream_n_crossover>
        <dream_p_gamma_unity>0.2</dream_p_gamma_unity>
        <dream_thin>1</dream_thin>
    </bayes_settings>
</configuration>
