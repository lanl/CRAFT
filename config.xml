<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Cleaning Metadata-->
    <cleaning_metadata>
        <drives>output_BCI_2pft.IELMFATES/,output_SLZ_2pft.IELMFATES/</drives><!--your files are located at $drive$case<-->
        <cases>BCI_2pft.IELMFATES,SLZ_2pft.IELMFATES</cases>
        <case_ids>1,2</case_ids><!--Numeric identifiers for each case<-->
        <n_runs>999</n_runs><!--Assumes these are 0-999<-->
        <varlist>Date,FATES_GPP,H2OSOIvalue4,H2OSOIvalue10,H2OSOIvalue1,FATES_LEAF_H2OPOT_SZPF_10,FATES_LEAF_H2OPOT_SZPF_22,FATES_LEAF_H2OPOT_SZPF_10,FATES_LEAF_H2OPOT_SZPF_22</varlist> <!--Always start with Date <-->
        <timestep>Month,Month,Month,Month,Month,DayMin,DayMin,DayMax,DayMax</timestep><!--Current options are Month, DayMin, DayMax<-->
        <parameter_loc>FATES_Param_samples_combined_clean.csv</parameter_loc><!--File with parameter combination <-->
    </cleaning_metadata>

    <!-- Neural Network Configuration-->
    <nn_config>
        <layer_sizes>44,1280,640,256,128,64,32,1</layer_sizes> <!--From top to bottom <-->
        <activation>relu</activation><!--Add dropout layers <-->
        <optimizer>adam</optimizer>
        <loss>mse</loss>
        <epochs>50</epochs>
        <batch_size>100</batch_size>
    </nn_config>

    <!-- Emulator Metadata-->
    <emulator_metadata>
        <save_name>CRAFT_BCI_Full</save_name>
        <thres>0.005</thres>
        <emulator_drive>data/Vars/</emulator_drive>
        <fates_samples>FATES_Param_samples_bci_ml.csv</fates_samples><!--Should be in CRAFT main <-->
        <model_type>rf</model_type><!--rf/nn--> 
        <nn_config>nn_config.csv</nn_config>
    </emulator_metadata>

    <!-- Emulator Settings-->
    <emulator_settings>
        <variable>
            <var_name>[H2OSOIvalue1,PFT1_LWPMax,PFT1_LWPMin,PFT2_LWPMax,PFT2_LWPMin]</var_name>
            <fates_runs>[H2OSOIvalue1MonthlyforML.csv,FATES_LEAF_H2OPOT_SZPF_10DailymaxforML.csv,FATES_LEAF_H2OPOT_SZPF_10DailyminforML.csv,FATES_LEAF_H2OPOT_SZPF_22DailymaxforMLV2.csv,FATES_LEAF_H2OPOT_SZPF_22DailyminforMLV2.csv]</fates_runs>
            <xs>[5,5,5,5,5]</xs> <!--where are the variables pythonic x_start<-->
            <xe>[46,46,46,46,46]</xe><!-- x_end<-->
            <y_i>[3,3,3,3,3]</y_i><!--where is y<-->
            <scaler>[1,1e-6,1e-6,1e-6,1e-6]</scaler><!-- scale_y<-->
            <downsample>[1,1,.1,.1,.1]</downsample><!-- downsample very large projects on small computer. <-->
        </variable>
    </emulator_settings>

    <!-- Bayes Settings -->
    <bayes_settings>
        <initialpos>45</initialpos>
        <steps>2000</steps>
        <adapt_interval>1000</adapt_interval>
        <burnin>1000</burnin>
        <model_list>['CRAFT_practice_FullH2OSOIvalue1','CRAFT_practice_FullPFT1_LWPMin','CRAFT_practice_FullPFT2_LWPMin']</model_list>
        <scaler_list>['CRAFT_practice_FullH2OSOIvalue1_Scalar','CRAFT_practice_FullPFT1_LWPMin_Scalar','CRAFT_practice_FullPFT2_LWPMin_Scalar']</scaler_list>
        <obs_list>["H2OSOI1",'LWP_min','LWP_min']</obs_list>
        <list1>["H2OSOI1",'LWP_min','LWP_min']</list1>
        <samples_file>FATES_Param_samples_slz_forML.csv</samples_file>
        <obsfile>Example_Obs_data/SLZ_Observations.csv</obsfile>
        <output_file>data/MCMC_runs/TestSLZ.csv</output_file>        
        <!-- MCMC Sampler Selection: 'adaptive' or 'dream' -->
        <sampler_method>dream</sampler_method>
        <!-- DREAM-specific settings (only used when sampler_method='dream') -->
        <dream_n_chains>5</dream_n_chains>
        <dream_delta>2</dream_delta>
        <dream_c>0.1</dream_c>
        <dream_c_star>1e-12</dream_c_star>
        <dream_n_crossover>3</dream_n_crossover>
        <dream_p_gamma_unity>0.2</dream_p_gamma_unity>
        <dream_thin>1</dream_thin>
    </bayes_settings>
</configuration>
